@page "/"

<PageTitle>CopilotScope</PageTitle>

<header class="topbar">
    <h1 class="brand">Copilot<span>Scope</span></h1>
    <nav class="nav">
        <a href="/" class="active">Sessions</a>
        <a href="/overview">Overview</a>
        <a href="/docs">Docs</a>
    </nav>
    <div class="conn @(_health is null ? "down" : "up")">
        @if (_health is null)
        {
            <text>collector unreachable</text>
        }
        else
        {
            <text>@_health.Environment · @_health.Sessions sessions · @(_health.Persistence ? "Postgres" : "in-memory")@(_health.Forwarding ? " · forwarding" : "")</text>
        }
    </div>
</header>

<div class="grid">
    <aside class="rail">
        <div class="rail-title">Sessions</div>
        @if (_sessions is null)
        {
            <div class="empty">Connecting to the collector…</div>
        }
        else if (_sessions.Count == 0)
        {
            <div class="empty">
                No sessions yet. Enable OTel in VS Code or run the demo generator:
                <code>dotnet run --project tools/CopilotScope.TelemetryGen</code>
            </div>
        }
        else
        {
            @foreach (var s in _sessions)
            {
                <button class="session @(s.Id == _selectedId ? "active" : "")" @onclick="() => SelectAsync(s.Id)">
                    <span class="session-id">@s.Id</span>
                    <span class="session-meta">@s.ChatCalls chat · @s.ToolCalls tools · @Ago(s.LastSeen)</span>
                    <span class="session-score grade-@s.Quality.Grade">@s.Quality.Score.ToString("0")</span>
                </button>
            }
        }
    </aside>

    <section class="main">
        @if (_detail is null)
        {
            <div class="empty big">Pick a session from the list — details and the quality score will appear here.</div>
        }
        else
        {
            var s = _detail.Summary;
            var q = s.Quality;

            <div class="panel vu-panel">
                <div class="panel-head">
                    <div>
                        <div class="panel-label">Session quality</div>
                        <div class="vu-score grade-@q.Grade">@q.Score.ToString("0.0") <small>/ 100 · @q.Grade · confidence @((q.Confidence * 100).ToString("0"))%</small></div>
                    </div>
                    <div class="head-actions">
                        <div class="panel-sub">@s.Id</div>
                        @if (_confirmDelete)
                        {
                            <button class="btn danger" @onclick="DeleteAsync">Confirm delete</button>
                            <button class="btn" @onclick="() => _confirmDelete = false">Cancel</button>
                        }
                        else
                        {
                            <button class="btn" @onclick="() => _confirmDelete = true">Delete session</button>
                        }
                    </div>
                </div>
                <div class="vu">
                    @for (var i = 0; i < 40; i++)
                    {
                        var lit = q.Score / 100.0 * 40 > i;
                        <span class="vu-seg @(lit ? SegClass(i) : "")"></span>
                    }
                </div>
                <div class="components">
                    @foreach (var c in q.Components)
                    {
                        <div class="component">
                            <div class="component-head">
                                <span>@c.Name <em>w=@c.Weight.ToString("0.00")</em></span>
                                <span>@((c.Value * 100).ToString("0"))</span>
                            </div>
                            <div class="bar"><span style="width:@(Pct(c.Value))%"></span></div>
                            <div class="component-detail">@c.Detail@(c.Samples == 0 ? " · prior" : "")</div>
                        </div>
                    }
                </div>
            </div>

            <div class="tiles">
                <div class="tile" data-tip="Cumulative prompt tokens sent across all LLM calls in this session — includes cached tokens re-sent each call. See Docs → Token semantics for why this is often large." tabindex="0"><b>@FmtTokens(s.InputTokens)</b><span>tokens in</span></div>
                <div class="tile" data-tip="Text the model generated for you. Main driver of response time and cost. Source: gen_ai.usage.output_tokens (VS Code + CLI)." tabindex="0"><b>@FmtTokens(s.OutputTokens)</b><span>tokens out</span></div>
                <div class="tile" data-tip="Prompt tokens served from the model's cache — a subset of tokens in, not additional. High ratio means context is being reused efficiently across calls. (VS Code + CLI, model-dependent)" tabindex="0"><b>@FmtTokens(s.CacheReadTokens)</b><span>cache read</span></div>
                <div class="tile" data-tip="Tokens actually freshly computed by the model: tokens in − cache read. This is the GPU work that happened — the rest was served from cache at negligible cost." tabindex="0"><b>@FmtTokens(Math.Max(0, s.InputTokens - s.CacheReadTokens))</b><span>net compute</span></div>
                <div class="tile" data-tip="Median wait before the first token appears — the 'how snappy does it feel' number. Under ~1 s feels instant; over 2 s breaks flow. (VS Code + CLI)" tabindex="0"><b>@s.TtftP50Ms.ToString("0") ms</b><span>TTFT p50</span></div>
                <div class="tile" data-tip="95th percentile of first-token wait — the slow outliers. A high p95 with a good p50 means occasional stalls. (VS Code + CLI)" tabindex="0"><b>@s.TtftP95Ms.ToString("0") ms</b><span>TTFT p95</span></div>
                <div class="tile" data-tip="How many times the model was called (one turn often makes several). ✗ counts failed calls — rate limits, timeouts. (VS Code + CLI)" tabindex="0"><b>@s.ChatCalls<i>@(s.ChatErrors > 0 ? $" ({s.ChatErrors}✗)" : "")</i></b><span>LLM calls</span></div>
                <div class="tile" data-tip="Tool executions the agent performed: file reads/edits, terminal commands, searches. ✗ counts tool failures. (VS Code + CLI)" tabindex="0"><b>@s.ToolCalls<i>@(s.ToolErrors > 0 ? $" ({s.ToolErrors}✗)" : "")</i></b><span>tool calls</span></div>
                <div class="tile" data-tip="Conversation turns vs agent invocations. Many turns per invocation can mean the agent needed a lot of back-and-forth to finish. (VS Code + CLI)" tabindex="0"><b>@s.Turns / @s.AgentInvocations</b><span>turns / invocations</span></div>
                <div class="tile" data-tip="Suggested edits you kept (✓) vs threw away (✗) — the most direct 'was it useful' signal. Editor-only: VS Code emits this, the CLI does not, so it stays 0 for CLI sessions." tabindex="0"><b>@s.EditsAccepted✓ @s.EditsRejected✗</b><span>edits</span></div>
                <div class="tile" data-tip="Your explicit thumbs up/down clicks in the chat UI. VS Code only — the CLI has no feedback buttons, so this stays 0 for CLI sessions." tabindex="0"><b>👍@s.ThumbsUp 👎@s.ThumbsDown</b><span>feedback</span></div>
                <div class="tile" data-tip="Lines of code added/removed by accepted suggestions. VS Code only — not emitted by the CLI." tabindex="0"><b>+@s.LinesAdded.ToString("0") −@s.LinesRemoved.ToString("0")</b><span>lines of code</span></div>
            </div>

            <div class="panel">
                <div class="panel-label">Turn analysis — @_detail.Turns.Algorithm</div>
                @if (_detail.Turns.Turns.Count == 0)
                {
                    <div class="empty">No completed turns yet.</div>
                }
                else
                {
                    <div class="findings">
                        @foreach (var f in _detail.Turns.Findings)
                        {
                            <div class="finding">@f</div>
                        }
                    </div>
                    @foreach (var t in _detail.Turns.Turns)
                    {
                        <div class="turn-row @(t.Index == _detail.Turns.BestIndex ? "best" : "") @(t.Index == _detail.Turns.WorstIndex ? "worst" : "")">
                            <span class="turn-idx">#@(t.Index + 1)</span>
                            <div class="bar wide"><span style="width:@(Pct(t.Score))%"></span></div>
                            <span class="turn-score">@((t.Score * 100).ToString("0"))</span>
                            <span class="turn-reasons">@string.Join(" · ", t.Reasons)</span>
                        </div>
                    }
                }
            </div>

            <div class="panel">
                <div class="panel-label">Insights — algorithm reports</div>
                <div class="insights">
                    @foreach (var r in _detail.Insights)
                    {
                        <div class="insight @(r.Status == "no-data" ? "muted" : "")">
                            <div class="insight-head">
                                <span class="insight-name">@r.Name</span>
                                @if (r.Score is { } sc)
                                {
                                    <span class="insight-score">@((sc * 100).ToString("0"))</span>
                                }
                            </div>
                            <div class="insight-algo">@r.Algorithm</div>
                            @if (r.Score is { } sv)
                            {
                                <div class="bar"><span style="width:@(Pct(sv))%"></span></div>
                            }
                            @foreach (var m in r.Metrics)
                            {
                                <div class="kv"><span>@m.Label</span><b>@m.Value</b></div>
                            }
                            @foreach (var f in r.Findings)
                            {
                                <div class="insight-finding">@f</div>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="columns">
                <div class="panel">
                    <div class="panel-label">Tools</div>
                    @if (_detail.Tools.Count == 0)
                    {
                        <div class="empty">No tool calls.</div>
                    }
                    else
                    {
                        var max = Math.Max(1, _detail.Tools.Max(t => t.Calls));
                        @foreach (var t in _detail.Tools)
                        {
                            <div class="tool-row">
                                <span class="tool-name">@t.Name</span>
                                <div class="bar wide">
                                    <span style="width:@(Pct(1.0 * t.Calls / max))%"></span>
                                </div>
                                <span class="tool-meta">@t.Calls×@(t.Errors > 0 ? $" · {t.Errors}✗" : "") · @t.AvgMs.ToString("0") ms</span>
                            </div>
                        }
                    }
                </div>

                <div class="panel">
                    <div class="panel-label">Models</div>
                    @foreach (var m in s.Models.OrderByDescending(m => m.Value))
                    {
                        <div class="tool-row">
                            <span class="tool-name">@m.Key</span>
                            <span class="tool-meta">@m.Value calls</span>
                        </div>
                    }

                    <div class="panel-label spaced">Errors</div>
                    @if (_detail.ErrorTypes.Count == 0)
                    {
                        <div class="ok-note">No errors ✓</div>
                    }
                    else
                    {
                        @foreach (var e in _detail.ErrorTypes.OrderByDescending(e => e.Value))
                        {
                            <div class="tool-row err"><span class="tool-name">@e.Key</span><span class="tool-meta">@e.Value×</span></div>
                        }
                    }

                    <div class="panel-label spaced">Context</div>
                    <div class="kv"><span>repo</span><b>@(s.Repository ?? "—")</b></div>
                    <div class="kv"><span>branch</span><b>@(s.Branch ?? "—")</b></div>
                    <div class="kv"><span>agent</span><b>@(s.Agent ?? "—")</b></div>
                    <div class="kv"><span>started</span><b>@s.FirstSeen.ToLocalTime().ToString("HH:mm:ss")</b></div>
                </div>
            </div>

            <div class="panel">
                <div class="panel-head">
                    <div class="panel-label">Prompts &amp; responses</div>
                    @if (_detail.Transcript.Count > 0)
                    {
                        <button class="btn" @onclick="() => _showChat = true">Open conversation</button>
                    }
                </div>
                @if (_detail.Transcript.Count == 0)
                {
                    <div class="empty">
                        No captured content — Copilot only sends prompt/response text when content capture is enabled on the client, and only for chats started after enabling it.
                        <code>VS Code: "github.copilot.chat.otel.captureContent": true</code>
                        <code>CLI: OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true (COPILOT_OTEL_CAPTURE_CONTENT does not exist)</code>
                    </div>
                }
                else
                {
                    <div class="chat-summary">
                        <span class="ok-note">Content capture is active ✓</span>
                        @_detail.Transcript.Count exchange(s) recorded, latest at
                        @_detail.Transcript[^1].Time.ToLocalTime().ToString("HH:mm:ss").
                        Open the read-only conversation view to browse them.
                    </div>
                }
            </div>

            <div class="panel">
                <div class="panel-label">Event feed (live)</div>
                <div class="feed">
                    @foreach (var e in _detail.Events)
                    {
                        <div class="feed-row kind-@e.Kind">
                            <span class="feed-time">@e.Time.ToLocalTime().ToString("HH:mm:ss")</span>
                            <span class="feed-kind">@e.Kind</span>
                            <span class="feed-text">@e.Summary</span>
                        </div>
                    }
                </div>
            </div>
            @if (_showChat)
            {
                <div class="modal-backdrop" @onclick="() => _showChat = false">
                    <div class="chat-window" @onclick:stopPropagation="true">
                        <div class="chat-head">
                            <div>
                                <div class="panel-label">Conversation — read only</div>
                                <div class="chat-head-sub">@s.Id</div>
                            </div>
                            <button class="btn" @onclick="() => _showChat = false">Close ✕</button>
                        </div>
                        <div class="chat-scroll">
                            @foreach (var entry in _detail.Transcript)
                            {
                                <div class="turn-sep">@entry.Time.ToLocalTime().ToString("HH:mm:ss") · @entry.Model@(entry.Turn >= 0 ? $" · turn {entry.Turn + 1}" : "")</div>
                                @foreach (var m in Messages(entry))
                                {
                                    <div class="msg @RoleClass(m.Role)">
                                        <div class="msg-role">@m.Role</div>
                                        <div class="msg-bubble">@m.Text</div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </section>
</div>
