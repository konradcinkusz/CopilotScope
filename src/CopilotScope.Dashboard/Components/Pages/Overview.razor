@page "/overview"
@implements IDisposable
@inject CollectorClient Collector

<PageTitle>CopilotScope — Overview</PageTitle>

<header class="topbar">
    <h1 class="brand">Copilot<span>Scope</span></h1>
    <nav class="nav">
        <a href="/">Sessions</a>
        <a href="/overview" class="active">Overview</a>
        <a href="/docs">Docs</a>
    </nav>
</header>

<div class="overview-main">
    @if (_overview is null)
    {
        <div class="empty big">Connecting to the collector…</div>
    }
    else if (_overview.Sessions == 0)
    {
        <div class="empty big">No sessions yet — chat with Copilot or run the demo generator, then come back.</div>
    }
    else
    {
        var o = _overview;
        var totalTokens = o.InputTokens + o.OutputTokens;

        <div class="panel">
            <div class="panel-label">All chats — token burn</div>
            <div class="tiles hero">
                <div class="tile" data-tip="Everything you burned across all recorded chats — prompt context plus generated output." tabindex="0"><b>@FmtTokens(totalTokens)</b><span>total tokens (in + out)</span></div>
                <div class="tile" data-tip="Total prompt context sent to models across all sessions." tabindex="0"><b>@FmtTokens(o.InputTokens)</b><span>input tokens</span></div>
                <div class="tile" data-tip="Total text generated by models across all sessions." tabindex="0"><b>@FmtTokens(o.OutputTokens)</b><span>output tokens</span></div>
                <div class="tile" data-tip="Prompt tokens served from cache instead of full reprocessing — effectively saved work and cost." tabindex="0"><b>@FmtTokens(o.CacheReadTokens)</b><span>cache read (saved)</span></div>
                <div class="tile" data-tip="Tokens written into the prompt cache — an upfront investment that pays off on subsequent calls." tabindex="0"><b>@FmtTokens(o.CacheCreationTokens)</b><span>cache written</span></div>
            </div>
        </div>

        <div class="tiles">
            <div class="tile" data-tip="Distinct chat conversations recorded by the collector." tabindex="0"><b>@o.Sessions</b><span>sessions</span></div>
            <div class="tile" data-tip="Model calls across all sessions; ✗ = failed calls." tabindex="0"><b>@o.ChatCalls<i>@(o.ChatErrors > 0 ? $" ({o.ChatErrors}✗)" : "")</i></b><span>LLM calls</span></div>
            <div class="tile" data-tip="Agent tool executions across all sessions; ✗ = failures." tabindex="0"><b>@o.ToolCalls<i>@(o.ToolErrors > 0 ? $" ({o.ToolErrors}✗)" : "")</i></b><span>tool calls</span></div>
            <div class="tile" data-tip="Total conversation turns across all sessions." tabindex="0"><b>@o.Turns</b><span>turns</span></div>
            <div class="tile" data-tip="Suggested edits kept vs discarded, summed over all sessions (VS Code only)." tabindex="0"><b>@o.EditsAccepted✓ @o.EditsRejected✗</b><span>edits</span></div>
            <div class="tile" data-tip="Explicit thumbs up/down across all sessions (VS Code only — the CLI has no feedback UI)." tabindex="0"><b>👍@o.ThumbsUp 👎@o.ThumbsDown</b><span>feedback</span></div>
            <div class="tile" data-tip="Mean composite quality score across all sessions. Individual scores carry confidence — check sessions with low confidence before comparing." tabindex="0"><b>@o.AvgQualityScore.ToString("0.0")</b><span>avg quality</span></div>
        </div>

        <div class="columns">
            <div class="panel">
                <div class="panel-label">Tokens per day (last 14 days with activity)</div>
                @{ var maxDay = Math.Max(1, o.Daily.Count > 0 ? o.Daily.Max(d => d.InputTokens + d.OutputTokens) : 1); }
                @foreach (var d in o.Daily)
                {
                    var dayTotal = d.InputTokens + d.OutputTokens;
                    <div class="tool-row">
                        <span class="tool-name">@d.Date.ToString("yyyy-MM-dd")</span>
                        <div class="bar wide"><span style="width:@(Pct(1.0 * dayTotal / maxDay))%"></span></div>
                        <span class="tool-meta">@FmtTokens(dayTotal) · @d.Sessions session(s)</span>
                    </div>
                }
            </div>

            <div class="panel">
                <div class="panel-label">Calls per model</div>
                @{ var maxModel = Math.Max(1, o.ModelCalls.Count > 0 ? o.ModelCalls.Values.Max() : 1); }
                @foreach (var m in o.ModelCalls.OrderByDescending(m => m.Value))
                {
                    <div class="tool-row">
                        <span class="tool-name">@m.Key</span>
                        <div class="bar wide"><span style="width:@(Pct(1.0 * m.Value / maxModel))%"></span></div>
                        <span class="tool-meta">@m.Value</span>
                    </div>
                }
            </div>
        </div>

        <div class="panel">
            <div class="panel-label">Top sessions by token burn</div>
            @{ var maxTop = Math.Max(1, o.TopSessions.Count > 0 ? o.TopSessions.Max(t => t.TotalTokens) : 1); }
            @foreach (var t in o.TopSessions)
            {
                <div class="tool-row">
                    <a class="tool-name link" href="/">@t.Id</a>
                    <div class="bar wide"><span style="width:@(Pct(1.0 * t.TotalTokens / maxTop))%"></span></div>
                    <span class="tool-meta">@FmtTokens(t.TotalTokens) · quality @t.QualityScore.ToString("0")</span>
                </div>
            }
        </div>
    }
</div>

@code {
    private OverviewDto? _overview;
    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        _overview = await Collector.GetOverviewAsync(_cts.Token);
        _ = PollAsync();
    }

    private async Task PollAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
            {
                _overview = await Collector.GetOverviewAsync(_cts.Token) ?? _overview;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private static string Pct(double v) =>
        (Math.Clamp(v, 0, 1) * 100).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);

    private static string FmtTokens(long n) => n switch
    {
        >= 1_000_000 => (n / 1_000_000.0).ToString("0.00") + "M",
        >= 1_000 => (n / 1_000.0).ToString("0.0") + "k",
        _ => n.ToString()
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
