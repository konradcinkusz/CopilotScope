# CopilotScope all-in-one image: collector (in-memory) + Blazor dashboard in ONE
# container — the "docker pull and go" distribution for GitHub Container Registry.
# No database: sessions live in memory (durable setup = docker-compose or Aspire).
#
# Build & publish (manual, no CI):
#   docker build -f Dockerfile.allinone -t ghcr.io/<user>/copilotscope:latest .
#   echo $GITHUB_PAT | docker login ghcr.io -u <user> --password-stdin
#   docker push ghcr.io/<user>/copilotscope:latest
#
# Run:
#   docker run --rm -p 4318:4318 -p 5200:5200 ghcr.io/<user>/copilotscope:latest
#   → dashboard: http://localhost:5200   OTLP ingest: http://localhost:4318

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY nuget.config .
COPY src/CopilotScope.Collector/ src/CopilotScope.Collector/
COPY src/CopilotScope.Dashboard/ src/CopilotScope.Dashboard/
RUN dotnet publish src/CopilotScope.Collector -c Release -o /app/collector \
 && dotnet publish src/CopilotScope.Dashboard -c Release -o /app/dashboard

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
COPY --from=build /app/collector collector/
COPY --from=build /app/dashboard dashboard/

ENV ASPNETCORE_ENVIRONMENT=Production
ENV Collector__BaseUrl=http://localhost:4318
EXPOSE 4318 5200

COPY <<'SH' /app/entrypoint.sh
#!/bin/sh
set -e
dotnet /app/collector/CopilotScope.Collector.dll --urls http://0.0.0.0:4318 &
COLLECTOR_PID=$!
trap 'kill $COLLECTOR_PID' TERM INT
dotnet /app/dashboard/CopilotScope.Dashboard.dll --urls http://0.0.0.0:5200 &
DASHBOARD_PID=$!
wait $DASHBOARD_PID
kill $COLLECTOR_PID 2>/dev/null || true
SH
RUN chmod +x /app/entrypoint.sh

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s \
  CMD wget -qO- http://localhost:4318/api/health || exit 1

ENTRYPOINT ["/app/entrypoint.sh"]
